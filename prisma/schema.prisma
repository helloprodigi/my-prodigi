generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider  = "postgresql"
}

model Activity {
  id          String   @id @default(uuid())
  slug        String   @unique
  title       String
  date        DateTime
  category    String
  excerpt     String
  coverImage  String
  contentHtml String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ExecutiveMember {
  id        Int      @id @default(autoincrement())
  year      String
  name      String
  nim       String
  prodi     String
  angkatan  String
  position  String
  linkedin  String?
  instagram String?
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([nim, year])
}

model HallOfFame {
  id          Int      @id @default(autoincrement())
  year        String
  title       String
  competition String
  image       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GalleryImage {
  id          Int      @id @default(autoincrement())
  year        String
  fileName    String
  imageUrl    String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AdmissionResult {
  id        Int      @id @default(autoincrement())
  nim       String   @unique
  name      String
  position  String
  isPassed  Boolean  @map("lolos")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id          String   @id // Mapping to Supabase auth.users id
  email       String   @unique
  name        String?
  nim         String?
  jurusan     String?
  angkatan    String?
  nomorWa     String?
  cvUrl       String?
  skills      String[]
  interests   String[]
  role        String   @default("talent") // Can be "talent", "asisten_lab", "admin"
  isOnboarded Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  competitionsCreated Competition[] @relation("CreatedCompetitions")
}

model Competition {
  id          String   @id @default(uuid())
  title       String
  organizer   String
  deadline    DateTime
  category    String   // e.g., "Belmawa", "Non-Belmawa", "Internal"
  skills      String[] // Tags e.g., ["Data Science", "UI/UX Design"]
  imageUrl    String?
  description String?
  link        String?
  status      String   @default("PENDING") // "PENDING", "APPROVED", "REJECTED"
  createdById String?
  createdBy   User?    @relation("CreatedCompetitions", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
