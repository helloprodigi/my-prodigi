generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Activity {
  id          String   @id @default(uuid())
  slug        String   @unique
  title       String
  date        DateTime
  category    String
  excerpt     String
  coverImage  String
  contentHtml String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ExecutiveMember {
  id        Int      @id @default(autoincrement())
  year      String
  name      String
  nim       String
  prodi     String
  angkatan  String
  position  String
  linkedin  String?
  instagram String?
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([nim, year])
}

model HallOfFame {
  id          Int      @id @default(autoincrement())
  year        String
  title       String
  competition String
  image       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GalleryImage {
  id          Int      @id @default(autoincrement())
  year        String
  fileName    String
  imageUrl    String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AdmissionResult {
  id        Int      @id @default(autoincrement())
  nim       String   @unique
  name      String
  position  String
  isPassed  Boolean  @map("lolos")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id          String   @id // Mapping to Supabase auth.users id
  email       String   @unique
  name        String?
  nim         String?
  jurusan     String?
  angkatan    String?
  nomorWa     String?
  cvUrl       String?
  photoUrl    String?
  skills      String[]
  interests   String[]
  role        String   @default("talent") // Can be "talent", "asisten_lab", "admin"
  isOnboarded Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  competitionsCreated Competition[] @relation("CreatedCompetitions")
  teamsAsLeader       Team[]        @relation("UserLedTeams")
  teamMemberships     TeamMember[]  @relation("UserTeamMemberships")
  notifications       Notification[]
}

model Competition {
  id          String   @id @default(uuid())
  title       String
  organizer   String
  deadline    DateTime
  category    String   // e.g., "Belmawa", "Non-Belmawa", "Internal"
  skills      String[] // Tags e.g., ["Data Science", "UI/UX Design"]
  imageUrl    String?
  description String?
  link        String?
  status      String   @default("PENDING") // "PENDING", "APPROVED", "REJECTED"
  createdById String?
  createdBy   User?    @relation("CreatedCompetitions", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  teams       Team[]    @relation("CompetitionTeams")
}

model Team {
  id                 String   @id @default(uuid())
  name               String
  memberCount        Int
  competitionId      String
  competition        Competition @relation("CompetitionTeams", fields: [competitionId], references: [id])
  leaderId           String?  
  leader             User?    @relation("UserLedTeams", fields: [leaderId], references: [id])
  requiredSkills     String[] 
  link               String
  category           String
  status             String   @default("IN_PROGRESS") // "IN_PROGRESS", "COMPLETED"
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  members            TeamMember[]
}

model TeamMember {
  id          String   @id @default(uuid())
  teamId      String
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation("UserTeamMemberships", fields: [userId], references: [id])
  status      String   @default("WAITING") // "WAITING", "APPROVED"
  slotNumber  Int?
  inviteToken String?
  invitedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([teamId, userId])
}

model Notification {
  id          String   @id @default(uuid())
  userId      String
  type        String   // "team_approve", "team_reject", "competition_new", "custom_info"
  title       String
  description String
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  
  user        User     @relation(fields: [userId], references: [id])
}
